{
  "run_name": "came_multigraph_pretrain",
  "checkpoint": "checkpoints/came_multigraph_pretrain_epoch8.pt",
  "args": {
    "multi_graph_config": "configs/multi_graph_example.json",
    "device": "cuda",
    "epochs": 8,
    "text_dim": 512,
    "image_dim": 512,
    "hidden_dim": 1024,
    "out_dim": 1024,
    "num_heads": 4,
    "dropout": 0.3,
    "attn_drop": 0.3,
    "temperature": 0.07,
    "w_txt_img": 1.0,
    "w_txt_fused": 0.1,
    "w_img_fused": 0.5,
    "lr": 0.0001,
    "weight_decay": 1e-06,
    "loss_batch_size": 1000,
    "use_gate": true,
    "align_weight": 0.1,
    "use_graph_structure": true,
    "graph_loss_weight": 0.1,
    "fusion_type": "hierarchical_moe",
    "use_moe": false,
    "num_experts": 18,
    "num_selected_experts": 2,
    "text_gat_layers": 2,
    "vision_gat_layers": 2,
    "ablation_single_gat": false,
    "single_modality": false,
    "modality": null,
    "amp": true,
    "grad_clip": 1.0,
    "grad_accum": 1,
    "embed_log_interval": 100,
    "save_dir": "checkpoints",
    "save_every": 4,
    "resume": null,
    "seed": null,
    "aux_loss_weight": 0.01
  }
}
